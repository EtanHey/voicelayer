{
  "_comment": "VoiceLayer MCP — daemon mode (recommended) or direct spawn",
  "mcpServers": {
    "voicelayer": {
      "_comment": "Daemon mode — install: ./launchd/install.sh",
      "command": "socat",
      "args": ["STDIO", "UNIX-CONNECT:/tmp/voicelayer-mcp.sock"]
    },
    "voicelayer-direct": {
      "_comment": "Direct spawn (fallback if daemon not running)",
      "command": "bun",
      "args": ["run", "src/mcp-server.ts"],
      "cwd": "~/Gits/voicelayer"
    }
  }
}
